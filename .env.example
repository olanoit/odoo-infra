# =============================================================================
# EXTENDRIX — Variables de entorno
# Copiar a .env y ajustar antes del primer arranque:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DATOS — PostgreSQL
# Contraseña del usuario 'odoo' en PostgreSQL (compartida por todas las instancias)
# Genera una segura con: openssl rand -base64 24 | tr -d '=+/' | cut -c1-24
# Ejemplo de contraseña fuerte (¡cámbiala!): Kp9_mTx4_rLq8_wNz2_Vj5s
# -----------------------------------------------------------------------------
POSTGRES_USER=odoo
POSTGRES_PASSWORD=CAMBIAR_ESTA_PASSWORD_SEGURA

# -----------------------------------------------------------------------------
# CERTBOT — Email para notificaciones de expiración SSL (Let's Encrypt)
# Ejemplo de email: support@extendrix.com
# -----------------------------------------------------------------------------
CERTBOT_EMAIL=admin@tudominio.com

# -----------------------------------------------------------------------------
# DOMINIOS — Agregar una variable DOMAIN_ por cada instancia Odoo
# El script setup-ssl.sh lee automáticamente todas las variables DOMAIN_*
#
# Formato sugerido: DOMAIN_{PROYECTO}_{ENTORNO}={subdominio}
# Ejemplos:
# DOMAIN_MICLIENTE_DEV=micliente-dev.tudominio.com
# DOMAIN_MICLIENTE_STA=micliente-sta.tudominio.com
# -----------------------------------------------------------------------------
# (sin dominios por defecto — agregar según los proyectos de este servidor)
